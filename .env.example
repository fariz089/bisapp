# ====== Salin file ini menjadi .env, lalu isi nilainya ======
# cp .env.example .env

# --- Database ---
POSTGRES_USER=bis
POSTGRES_PASSWORD=ubah-password-ini
POSTGRES_DB=bisdb

# --- Backend ---
BACKEND_PORT=4000
JWT_SECRET=ganti-dengan-string-acak-panjang
WEBHOOK_SECRET=ganti-dengan-string-acak-lain

# --- Akun admin awal (untuk login dashboard) ---
ADMIN_EMAIL=admin@bis.local
ADMIN_PASSWORD=admin123

# --- LLM / AI Agent (OpenAI-compatible, mis. Nous Hermes provider Anda) ---
# JANGAN tempel key di sini lalu commit ke git. File .env harus masuk .gitignore.
LLM_BASE_URL=https://api.codecrafters.id/v1
LLM_API_KEY=isi-key-anda-disini
LLM_MODEL=deepseek-v4-flash:free

# --- Sinkronisasi pesan lama saat pertama login (whatsapp-web.js) ---
SYNC_HISTORY=true
SYNC_LIMIT=30

# --- Siklus sesi otomatis (follow-up + auto-close) ---
# AI menyenggol customer yang diam setelah FOLLOWUP_AFTER_MIN menit,
# lalu menutup sesi otomatis setelah CLOSE_AFTER_MIN menit. MAX_FOLLOWUPS = batas nudge.
FOLLOWUP_AFTER_MIN=3
CLOSE_AFTER_MIN=5
MAX_FOLLOWUPS=1
# Seberapa sering scheduler memindai (detik). Kecilkan untuk reaksi lebih cepat.
LIFECYCLE_TICK_SEC=30
# Pesan penutup (opsional; kosongkan untuk pakai default).
# CLOSING_TEXT=

# --- Zona waktu (untuk jam kerja & pengingat H-1) ---
TZ=Asia/Jakarta

# --- Pembayaran ---
# URL publik aplikasi agar link pembayaran bisa diakses customer dari HP, mis. https://cs.usahabis.com
# Bila kosong, link memakai path relatif (/pay/REF) — hanya jalan bila customer buka dari domain yang sama.
PUBLIC_URL=

# --- Pengingat keberangkatan H-1 ---
# Jam (0-23, zona TZ) saat pengingat dikirim. Default 09:00.
REMINDER_HOUR=9

# --- Broadcast (rate-limit agar nomor WA aman) ---
# Jeda antar pesan (ms), acak antara MIN..MAX. Jangan terlalu kecil.
BROADCAST_MIN_DELAY_MS=6000
BROADCAST_MAX_DELAY_MS=12000
# Batas penerima per kampanye.
BROADCAST_MAX_PER_RUN=500

# --- Eskalasi pintar (presence agen) ---
# Agen dianggap online bila terlihat dalam N detik terakhir (heartbeat tiap 30 dtk).
AGENT_ONLINE_GRACE_SEC=90

# --- Cloudflare Tunnel (akses publik tanpa port forwarding) ---
# Buat tunnel di Cloudflare Zero Trust -> Networks -> Tunnels, lalu salin token-nya.
# Di dashboard tunnel, arahkan Public Hostname (mis. cs.usahabis.com) ke http://backend:3000
# Kosongkan bila tidak memakai tunnel (container cloudflared akan gagal start, abaikan saja).
CLOUDFLARE_TUNNEL_TOKEN=isi-token-tunnel-cloudflare-disini
